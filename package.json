  "scripts": {
    "start": "concurrently npm:start:app",
    "start:app": "cross-env HOT_RELOAD=yes NODE_ENV=development webpack serve --config config/webpack.dev.js",
    "build": "cross-env HOT_RELOAD=no NODE_ENV=production webpack --config config/webpack.prod.js",
    "test": "cross-env DEBUG_PRINT_LIMIT=300000 HOT_RELOAD=no jest -c jest.config.js",
    "test:watch-all": "cross-env HOT_RELOAD=no jest -c jest.config.js --watchAll",
    "test:coverage": "cross-env HOT_RELOAD=no jest -c jest.config.js --coverage --watchAll=false",
    "coverage:CI": "cross-env HOT_RELOAD=no npm run coverage:run-in-band",
    "coverage:run-in-band": "cross-env HOT_RELOAD=no jest -c jest.config.js --coverage --runInBand",
    "lint": "eslint ./src",
    "lint:fix": "eslint --fix --ext .js,.jsx .",
    "analyzer": "cross-env HOT_RELOAD=no ANALYZER=true npm run build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ],
    "rules": {
      "react/display-name": "off",
      "react/no-unknown-property": "off",
      "react/react-in-jsx-scope": "off",
      "react/jsx-uses-vars": "off",
      "react/jsx-no-undef": "off",
      "no-unused-vars": "off",
      "react/prop-types": "off",
      "react/jsx-no-duplicate-props": "off",
      "react/jsx-no-target-blank": "off",
      "no-empty": "off",
      "no-prototype-builtins": "off",
      "react/jsx-key": "off",
      "no-useless-escape": "off",
      "camelcase": "off",
      "react-hooks/exhaustive-deps": 0,
      "eqeqeq": 0
    }
  },
  "jestSonar": {
    "sonar56x": true,
    "reportPath": "testResults",
    "reportFile": "sonar-report.xml",
    "indent": 4
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
